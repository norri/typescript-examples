{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@app/api-types": ["../../packages/api-types/src/index.ts"],
      "@app/api": ["../../apps/api/src/app.ts"]
    }
  },
  "include": ["src"]
}
